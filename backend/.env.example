# Vessel Compliance Agent - Environment Variables
# Copy to .env and fill in your API keys

# MarineTraffic API
MARINE_TRAFFIC_API_KEY=

# Spire Maritime API
SPIRE_API_KEY=

# Equasis (free registration at equasis.org)
EQUASIS_USERNAME=
EQUASIS_PASSWORD=

# Database
DATABASE_URL=sqlite+aiosqlite:///data/vessel_compliance.db
